# Environment configuration for VeriForm
# Copy this file to .env and fill in values.

# -----------------------------------------------
# Application
# -----------------------------------------------
VERIFORM_ENV=development          # development | production
VERIFORM_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# -----------------------------------------------
# API Server
# -----------------------------------------------
VERIFORM_API_HOST=127.0.0.1
VERIFORM_API_PORT=8000

# -----------------------------------------------
# Playwright
# -----------------------------------------------
VERIFORM_BROWSER=chromium         # chromium | firefox | webkit
VERIFORM_HEADLESS=true
VERIFORM_TIMEOUT_MS=30000         # Default navigation timeout (ms)

# -----------------------------------------------
# Reports
# -----------------------------------------------
VERIFORM_REPORTS_DIR=reports

# -----------------------------------------------
# Phase 3 (not active)
# -----------------------------------------------
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_SCHEMA=
# SNOWFLAKE_WAREHOUSE=
