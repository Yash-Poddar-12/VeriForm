VERIFORM_ENV=development
VERIFORM_LOG_LEVEL=INFO

# API settings
VERIFORM_API_HOST=127.0.0.1
VERIFORM_API_PORT=8000

# Browser config
VERIFORM_BROWSER=chromium
VERIFORM_HEADLESS=true
VERIFORM_TIMEOUT_MS=30000

# Persistence settings
VERIFORM_DATABASE_URL=sqlite+aiosqlite:///veriform.db
VERIFORM_ARTIFACTS_DIR=artifacts

# Concurrency limits
VERIFORM_MAX_CONCURRENT_RUNS=2
VERIFORM_MAX_WORKFLOW_DEPTH=15
VERIFORM_MAX_STATES_EXPLORED=100
VERIFORM_MAX_TRANSITIONS_PER_STATE=20
